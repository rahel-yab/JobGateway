{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "weather-route": {
        "ClusterId": "weather-cluster",
        "RateLimiterPolicy": "customPolicy",
        "Match": {
          "Path": "/get-weather/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/get-weather" }
        ]
      }
    },
    "Clusters": {
      "weather-cluster": {
        "LoadBalancingPolicy": "RoundRobin", 
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5038" 
          }
        }
      }
    }
  }
}